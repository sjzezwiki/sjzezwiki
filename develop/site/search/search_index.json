49\u6708\uff0c\u73b0\u53c8\u540d\u6cb3\u5317\u7701\u5b9e\u9a8c\u4e2d\u5b66\u3002","title":"\u897f\u6821\u533a"},{"location":"\u5b66\u6821\u6982\u51b5/4west/#_1","text":"","title":"\u897f\u6821\u533a"},{"location":"\u5b66\u6821\u6982\u51b5/4west/#_2","text":"\u77f3\u5bb6\u5e84\u4e8c\u4e2d\u59cb\u5efa\u4e8e1948\u5e749\u6708\uff0c\u73b0\u53c8\u540d\u6cb3\u5317\u7701\u5b9e\u9a8c\u4e2d\u5b66\u3002","title":"\u7b80\u4ecb"},{"location":"\u5b66\u6821\u6982\u51b5/5shimen/","text":"\u77f3\u95e8\u6821\u533a \u7b80\u4ecb \u77f3\u5bb6\u5e84\u4e8c\u4e2d\u59cb\u5efa\u4e8e1948\u5e749\u6708\uff0c\u73b0\u53c8\u540d\u6cb3\u5317\u7701\u5b9e\u9a8c\u4e2d\u5b66\u3002","title":"\u77f3\u95e8\u6821\u533a"},{"location":"\u5b66\u6821\u6982\u51b5/5shimen/#_1","text":"","title":"\u77f3\u95e8\u6821\u533a"},{"location":"\u5b66\u6821\u6982\u51b5/5shimen/#_2","text":"\u77f3\u5bb6\u5e84\u4e8c\u4e2d\u59cb\u5efa\u4e8e1948\u5e749\u6708\uff0c\u73b0\u53c8\u540d\u6cb3\u5317\u7701\u5b9e\u9a8c\u4e2d\u5b66\u3002","title":"\u7b80\u4ecb"},{"location":"\u62db\u751f\u4fe1\u606f/0gen/","text":"\u6982\u8ff0 \u7248\u6743 \u672c\u9875\u9762\u5185\u5bb9\u6765\u81ea\u767e\u5ea6\u8d34\u5427@OttoHans \u5e38\u8bc6\u6027\u95ee\u9898 1.\u4e8c\u4e2d\u5206\u51e0\u4e2a\u6821\u533a\uff1f \u5317\u6821\u533a\uff08\u516c\u529e\uff09\uff0c\u5357\u6821\u533a\uff08\u516c\u53c2\u6c11\uff09\uff0c\u897f\u6821\u533a\uff08\u516c\u529e\uff09\uff0c\u77f3\u95e8\u5b9e\u9a8c\u5b66\u6821\uff08\u6c11\u529e\u80a1\u4efd\u5236\uff09\uff0c\u6da6\u5fb7\u5b66\u6821\uff08\u6c11\u529e\u5de5\u5206\u5236\uff09\uff0c\u96c4\u5b89\u6821\u533a\uff08\u516c\u7acb\u5b89\u65b0\u4e2d\u5b66\uff0c\u5bf9\u53e3\u5171\u5efa\uff09\u3002 2.\u4e8c\u4e2d\u7684\u521d\u4e2d\u5728\u90a3\u4e2a\u6821\u533a\uff1f \u897f\u6821\u533a\uff0c\u77f3\u95e8\u5b9e\u9a8c\u5b66\u6821\uff0c\u6da6\u5fb7\u5b66\u6821\u3002 3.\u4e8c\u4e2d\u90a3\u4e9b\u6821\u533a\u62db\u6536\u975e\u77f3\u5bb6\u5e84\u5e02\u533a\u751f\u6e90\uff1f \u5357\u6821\u533a\uff0c\u77f3\u95e8\u5b9e\u9a8c\u5b66\u6821\uff0c\u6da6\u5fb7\u5b66\u6821\uff0c\u96c4\u5b89\u6821\u533a\uff08\u4ec5\u96c4\u5b89\u65b0\u533a\uff09\u3002 \u54ea\u4e2a\u6821\u533a\u597d\uff1f 1.\u5bf9\u77f3\u5bb6\u5e84\u672c\u5730\u751f\u6e90\uff1a \u5f55\u53d6\u5206\u5728\u90a3\u5462\uff0c\u7528\u6211\u8bf4\u5417\uff1f 2.\u5bf9\u5916\u5730\u751f\u6e90\uff1a \u5357\u6821\u533a\u597d\u3002 3.\u90a3\u662f\u5357\u6821\u597d\u8fd8\u662f\u5317\u6821\u597d\uff1f \u5982\u679c\u5e02\u533a\u751f\u6e90\u95ee\u8fd9\u4e2a\u9898\uff0c\u90a3\u4e48\u7b54\u6848\u662f\uff1a\u6211\u4e0d\u7ba1\u5b59\u5927\u70ae\u798f\u5c71\u9505\u53c8\u5728\u6821\u5185\u6821\u5916\u7ed9\u5927\u5bb6\u704c\u5565\u836f\u4e86\uff0c\u5e02\u5185\u5c16\u5b50\u6765\u4e8c\u4e2d\u7684\u4e3b\u8981\u6d41\u5411\u5317\u6821\u662f\u5ba2\u89c2\u4e8b\u5b9e\uff0c\u5357\u6821\u5e02\u533a\u751f\u6e90\u8d28\u91cf\u518d\u63d0\u5347\u4e5f\u6709\u9650\uff0c\u5357\u6821\u91d1\u5b57\u5854\u5854\u5c16\u8fd8\u662f\u5916\u5730\u751f\u6e90\u3002 \u90a3\u4e48\u4f60\u8bf4\u8c01\u597d\uff1f\u8c01\u597d\u4f60\u4e5f\u4e0d\u662f\u91cc\u9762\u7684\u5854\u5c16\u90a3\u4e00\u6279\u3002 4.\u90a3\u5357\u6821\u548c\u6da6\u5fb7\u5462\uff1f \u5916\u5730\u5b66\u751f\u7684\u8bdd\uff0c\u4f60\u8981\u662f\u80fd\u53bb\u6da6\u5fb7\u201c\u7701\u7406\u201d\uff0c\u4f60\u5c31\u5f53\u662f\u4f60\u53bb\u4e86\u5357\u6821\u91cd\u70b9\u73ed\u4e86\u5427\uff0c\u8981\u662f\u521b\u65b0\u5b9e\u9a8c...\u201c\u90a3\u8fd9\u65e5\u5b50\u8fd8\u51d1\u5408\u7740\u80fd\u8fc7\u201d\u3002 \u795d\u597d\u3002 \uff08\u53ea\u8c08\u73b0\u72b6\uff0c\u4e0d\u8c08\u672a\u6765\u3002\u6bd5\u7adf\uff0c\u4eba\u751f\u6709\u9650\uff0c\u5e0c\u671b\u65e0\u9650\uff09 \u65b0\u9ad8\u8003\u6539\u9769\u540e\u7684\u5206\u73ed\u95ee\u9898 3+1+2\u6a21\u5f0f\u4e0b\uff0c\u5317\u6821\uff08\u672c\u90e8\uff09\u3001\u5357\u6821\u5728\u51e0\u6b21\u9884\u9009\u540e\u7684\u6b63\u5f0f\u9009\u79d1\u4e2d\u5f00\u653e\u4e86\u5168\u90e8\u5341\u4e8c\u79cd\u9009\u62e9\uff0c\u4e0d\u505a\u9009\u79d1\u9650\u5236\u3002\u9009\u79d1\u5b8c\u6210\u540e\u5b66\u6821\u6839\u636e\u539f\u73ed\u7ea7\u5c42\u6b21\u5728\u540c\u5c42\u6b21\u5185\u6839\u636e\u5b66\u751f\u4e2a\u4eba\u7684\u9009\u79d1\u610f\u613f\u5e73\u884c\u5206\u73ed\uff08\u5373\u7701\u7406\u5728\u7701\u7406\u5185\u90e8\u5206\uff0c\u91cd\u70b9\u5728\u91cd\u70b9\u5185\u90e8\u5206\uff0c\u666e\u73ed\u5728\u666e\u73ed\u5185\u90e8\u5206\uff09\uff0c\u5c3d\u91cf\u7ef4\u6301\u884c\u653f\u73ed\u5b8c\u6574\u4e14\u6559\u5b66\u4e0a\u4ee5\u884c\u653f\u73ed\u4e3a\u4e3b\uff0c\u8f85\u4ee5\u5c0f\u8d70\u73ed\uff08\u5b9a3\u4e3a\u4e3b\uff0c\u5b9a2\u8d701\u6b21\u4e4b\uff0c\u5c11\u91cf\u8d703\uff09 \u897f\u6821\u548c\u6da6\u5fb7\u5b66\u6821\u7684\u60c5\u51b5\u5176\u5b9e\u4e5f\u5dee\u4e0d\u591a\uff0c\u4f46\u662f\u897f\u6821\u6700\u540e\u6839\u636e\u9884\u9009\u7ed3\u679c\u7ed9\u7684\u51e0\u79cd\u56fa\u5b9a\u7ec4\u5408\uff08\u6bd5\u7adf\u897f\u6821\u73b0\u5728\u5e74\u7ea7\u592a\u5c0f\uff09\u3002 \u5373\u56db\u6821\u533a\u9ad8\u4e2d\u90fd\u5728\u9ad8\u4e00\u4e0b\u5b66\u671f\u9009\u79d1\u540e\u5f00\u59cb\u6309\u9009\u79d1\u540e\u7684\u65b0\u73ed\u7ea7\u4e0a\u8bfe\u3002 \u8fd9\u662f\u672c\u5e74\u5ea6\u60c5\u51b5\uff082018\u7ea7\u9ad8\u4e00\uff09\uff0c\u4ee5\u540e\u65b0\u751f\u5e94\u8be5\u4e0d\u4f1a\u6709\u5927\u7684\u53d8\u5316\u3002","title":"\u6982\u8ff0"},{"location":"\u62db\u751f\u4fe1\u606f/0gen/#_1","text":"","title":"\u6982\u8ff0"},{"location":"\u62db\u751f\u4fe1\u606f/0gen/#_2","text":"\u672c\u9875\u9762\u5185\u5bb9\u6765\u81ea\u767e\u5ea6\u8d34\u5427@OttoHans","title":"\u7248\u6743"},{"location":"\u62db\u751f\u4fe1\u606f/0gen/#_3","text":"1.\u4e8c\u4e2d\u5206\u51e0\u4e2a\u6821\u533a\uff1f \u5317\u6821\u533a\uff08\u516c\u529e\uff09\uff0c\u5357\u6821\u533a\uff08\u516c\u53c2\u6c11\uff09\uff0c\u897f\u6821\u533a\uff08\u516c\u529e\uff09\uff0c\u77f3\u95e8\u5b9e\u9a8c\u5b66\u6821\uff08\u6c11\u529e\u80a1\u4efd\u5236\uff09\uff0c\u6da6\u5fb7\u5b66\u6821\uff08\u6c11\u529e\u5de5\u5206\u5236\uff09\uff0c\u96c4\u5b89\u6821\u533a\uff08\u516c\u7acb\u5b89\u65b0\u4e2d\u5b66\uff0c\u5bf9\u53e3\u5171\u5efa\uff09\u3002 2.\u4e8c\u4e2d\u7684\u521d\u4e2d\u5728\u90a3\u4e2a\u6821\u533a\uff1f \u897f\u6821\u533a\uff0c\u77f3\u95e8\u5b9e\u9a8c\u5b66\u6821\uff0c\u6da6\u5fb7\u5b66\u6821\u3002 3.\u4e8c\u4e2d\u90a3\u4e9b\u6821\u533a\u62db\u6536\u975e\u77f3\u5bb6\u5e84\u5e02\u533a\u751f\u6e90\uff1f \u5357\u6821\u533a\uff0c\u77f3\u95e8\u5b9e\u9a8c\u5b66\u6821\uff0c\u6da6\u5fb7\u5b66\u6821\uff0c\u96c4\u5b89\u6821\u533a\uff08\u4ec5\u96c4\u5b89\u65b0\u533a\uff09\u3002","title":"\u5e38\u8bc6\u6027\u95ee\u9898"},{"location":"\u62db\u751f\u4fe1\u606f/0gen/#_4","text":"1.\u5bf9\u77f3\u5bb6\u5e84\u672c\u5730\u751f\u6e90\uff1a \u5f55\u53d6\u5206\u5728\u90a3\u5462\uff0c\u7528\u6211\u8bf4\u5417\uff1f 2.\u5bf9\u5916\u5730\u751f\u6e90\uff1a \u5357\u6821\u533a\u597d\u3002 3.\u90a3\u662f\u5357\u6821\u597d\u8fd8\u662f\u5317\u6821\u597d\uff1f \u5982\u679c\u5e02\u533a\u751f\u6e90\u95ee\u8fd9\u4e2a\u9898\uff0c\u90a3\u4e48\u7b54\u6848\u662f\uff1a\u6211\u4e0d\u7ba1\u5b59\u5927\u70ae\u798f\u5c71\u9505\u53c8\u5728\u6821\u5185\u6821\u5916\u7ed9\u5927\u5bb6\u704c\u5565\u836f\u4e86\uff0c\u5e02\u5185\u5c16\u5b50\u6765\u4e8c\u4e2d\u7684\u4e3b\u8981\u6d41\u5411\u5317\u6821\u662f\u5ba2\u89c2\u4e8b\u5b9e\uff0c\u5357\u6821\u5e02\u533a\u751f\u6e90\u8d28\u91cf\u518d\u63d0\u5347\u4e5f\u6709\u9650\uff0c\u5357\u6821\u91d1\u5b57\u5854\u5854\u5c16\u8fd8\u662f\u5916\u5730\u751f\u6e90\u3002 \u90a3\u4e48\u4f60\u8bf4\u8c01\u597d\uff1f\u8c01\u597d\u4f60\u4e5f\u4e0d\u662f\u91cc\u9762\u7684\u5854\u5c16\u90a3\u4e00\u6279\u3002 4.\u90a3\u5357\u6821\u548c\u6da6\u5fb7\u5462\uff1f \u5916\u5730\u5b66\u751f\u7684\u8bdd\uff0c\u4f60\u8981\u662f\u80fd\u53bb\u6da6\u5fb7\u201c\u7701\u7406\u201d\uff0c\u4f60\u5c31\u5f53\u662f\u4f60\u53bb\u4e86\u5357\u6821\u91cd\u70b9\u73ed\u4e86\u5427\uff0c\u8981\u662f\u521b\u65b0\u5b9e\u9a8c...\u201c\u90a3\u8fd9\u65e5\u5b50\u8fd8\u51d1\u5408\u7740\u80fd\u8fc7\u201d\u3002 \u795d\u597d\u3002 \uff08\u53ea\u8c08\u73b0\u72b6\uff0c\u4e0d\u8c08\u672a\u6765\u3002\u6bd5\u7adf\uff0c\u4eba\u751f\u6709\u9650\uff0c\u5e0c\u671b\u65e0\u9650\uff09","title":"\u54ea\u4e2a\u6821\u533a\u597d\uff1f"},{"location":"\u62db\u751f\u4fe1\u606f/0gen/#_5","text":"3+1+2\u6a21\u5f0f\u4e0b\uff0c\u5317\u6821\uff08\u672c\u90e8\uff09\u3001\u5357\u6821\u5728\u51e0\u6b21\u9884\u9009\u540e\u7684\u6b63\u5f0f\u9009\u79d1\u4e2d\u5f00\u653e\u4e86\u5168\u90e8\u5341\u4e8c\u79cd\u9009\u62e9\uff0c\u4e0d\u505a\u9009\u79d1\u9650\u5236\u3002\u9009\u79d1\u5b8c\u6210\u540e\u5b66\u6821\u6839\u636e\u539f\u73ed\u7ea7\u5c42\u6b21\u5728\u540c\u5c42\u6b21\u5185\u6839\u636e\u5b66\u751f\u4e2a\u4eba\u7684\u9009\u79d1\u610f\u613f\u5e73\u884c\u5206\u73ed\uff08\u5373\u7701\u7406\u5728\u7701\u7406\u5185\u90e8\u5206\uff0c\u91cd\u70b9\u5728\u91cd\u70b9\u5185\u90e8\u5206\uff0c\u666e\u73ed\u5728\u666e\u73ed\u5185\u90e8\u5206\uff09\uff0c\u5c3d\u91cf\u7ef4\u6301\u884c\u653f\u73ed\u5b8c\u6574\u4e14\u6559\u5b66\u4e0a\u4ee5\u884c\u653f\u73ed\u4e3a\u4e3b\uff0c\u8f85\u4ee5\u5c0f\u8d70\u73ed\uff08\u5b9a3\u4e3a\u4e3b\uff0c\u5b9a2\u8d701\u6b21\u4e4b\uff0c\u5c11\u91cf\u8d703\uff09 \u897f\u6821\u548c\u6da6\u5fb7\u5b66\u6821\u7684\u60c5\u51b5\u5176\u5b9e\u4e5f\u5dee\u4e0d\u591a\uff0c\u4f46\u662f\u897f\u6821\u6700\u540e\u6839\u636e\u9884\u9009\u7ed3\u679c\u7ed9\u7684\u51e0\u79cd\u56fa\u5b9a\u7ec4\u5408\uff08\u6bd5\u7adf\u897f\u6821\u73b0\u5728\u5e74\u7ea7\u592a\u5c0f\uff09\u3002 \u5373\u56db\u6821\u533a\u9ad8\u4e2d\u90fd\u5728\u9ad8\u4e00\u4e0b\u5b66\u671f\u9009\u79d1\u540e\u5f00\u59cb\u6309\u9009\u79d1\u540e\u7684\u65b0\u73ed\u7ea7\u4e0a\u8bfe\u3002 \u8fd9\u662f\u672c\u5e74\u5ea6\u60c5\u51b5\uff082018\u7ea7\u9ad8\u4e00\uff09\uff0c\u4ee5\u540e\u65b0\u751f\u5e94\u8be5\u4e0d\u4f1a\u6709\u5927\u7684\u53d8\u5316\u3002","title":"\u65b0\u9ad8\u8003\u6539\u9769\u540e\u7684\u5206\u73ed\u95ee\u9898"},{"location":"\u62db\u751f\u4fe1\u606f/1north/","text":"\u6821\u672c\u90e8 \u7248\u6743 \u672c\u9875\u9762\u5185\u5bb9\u6765\u81ea\u767e\u5ea6\u8d34\u5427@OttoHans \u62a5\u8003\u6307\u5357 1.\u4e0d\u662f\u8bf4\u5317\u6821\u533a\u53ea\u62db\u6536\u5e02\u533a\u751f\u6e90\uff0c\u90a3\u4e3a\u4ec0\u4e48\u6211\u8ba4\u8bc6\u7684\u6709\u5916\u5730\u7684\u4e5f\u5728\u5317\u6821\u533a\u4e0a\u5b66\uff1f \u77f3\u5bb6\u5e84\u5e02\u533a\u751f\u6e90\u8eab\u4efd\u7684\u8ba4\u5b9a\u6807\u51c6\u662f\u62e5\u6709\u77f3\u5bb6\u5e84\u5e02\u533a\u521d\u4e2d\u5b66\u7c4d\u5e76\u5728\u77f3\u5bb6\u5e84\u5e02\u62a5\u540d\u53c2\u52a0\u4e2d\u8003\u7684\u5b66\u751f\uff0c\u56e0\u6b64\u770b\u7684\u662f\u5b66\u7c4d\uff0c\u4e0d\u662f\u6237\u7c4d\u3002 \u53e6\uff0c\u822a\u7a7a\u73ed\u4ea6\u62db\u6536\u5916\u5730\u5b66\u751f\u3002 2.\u4e0a\u5317\u6821\u5927\u6982\u8981\u591a\u5c11\u5206\uff1f \u8bf7\u770b\u5e02\u5185\u56db\u533a\u6392\u540d\uff0c\u81f3\u5c11\u56db\u533a\u524d2000\u540d\u3002 3.\u5317\u6821\u62dbXXX\u7279\u957f\u751f\u5417\uff1f \u4e0d\u8981\u4ee5\u5f80\u5e74\u60c5\u51b5\u4e3a\u51c6\uff0c\u8bf7\u4ee5\u5f53\u5e74\u5ea6\u5e02\u6559\u80b2\u5c40\u6838\u51c6\u7684\u62db\u751f\u8ba1\u5212\u4e3a\u51c6\u3002\u7ecf\u9a8c\u4e3b\u4e49\u8981\u4e0d\u5f97\uff0c\u6bd4\u5982\u4e4b\u524d\u5df2\u7ecf\u5f88\u591a\u5e74\u4e0d\u62db\u97f3\u4e50\u7279\u957f\u4e86\uff0c\u7ed3\u679c\u53bb\u5e74\u8ba1\u5212\u91cc\u5c31\u6279\u97f3\u4e50\u7684\u540d\u989d\u4e86\u3002 4.\u5317\u6821\u73ed\u578b\uff1f \u73b0\u6709\u822a\u7a7a\u73ed\uff0c\u666e\u901a\u73ed\uff0c\u91cd\u70b9\u73ed\uff0c\u6cb3\u5317\u7701\u7406\u79d1\u5b9e\u9a8c\u73ed\uff08\u5206\u9ad8\u8003\u73ed\u548c\u7ade\u8d5b\u73ed\uff09\u3002 5.\u5317\u6821\u80fd\u4f4f\u5bbf\u5417\uff1f \u80fd\uff0c\u65b0\u5bbf\u820d\u72ec\u7acb\u536b\u6d74\uff0c\u6c34\u6696\u9f50\u5168\uff0c\u6709\u7a7a\u8c03\uff0c6\u4eba\u95f4\u3002\u5bbf\u820d\u697c\u5927\u6982\u80fd\u4f4f\u4e00\u5343\u4eba\u5de6\u53f3\uff0c\u4f4f\u5bbf\u9700\u7533\u8bf7\u3002","title":"\u6821\u672c\u90e8"},{"location":"\u62db\u751f\u4fe1\u606f/1north/#_1","text":"","title":"\u6821\u672c\u90e8"},{"location":"\u62db\u751f\u4fe1\u606f/1north/#_2","text":"\u672c\u9875\u9762\u5185\u5bb9\u6765\u81ea\u767e\u5ea6\u8d34\u5427@OttoHans","title":"\u7248\u6743"},{"location":"\u62db\u751f\u4fe1\u606f/1north/#_3","text":"1.\u4e0d\u662f\u8bf4\u5317\u6821\u533a\u53ea\u62db\u6536\u5e02\u533a\u751f\u6e90\uff0c\u90a3\u4e3a\u4ec0\u4e48\u6211\u8ba4\u8bc6\u7684\u6709\u5916\u5730\u7684\u4e5f\u5728\u5317\u6821\u533a\u4e0a\u5b66\uff1f \u77f3\u5bb6\u5e84\u5e02\u533a\u751f\u6e90\u8eab\u4efd\u7684\u8ba4\u5b9a\u6807\u51c6\u662f\u62e5\u6709\u77f3\u5bb6\u5e84\u5e02\u533a\u521d\u4e2d\u5b66\u7c4d\u5e76\u5728\u77f3\u5bb6\u5e84\u5e02\u62a5\u540d\u53c2\u52a0\u4e2d\u8003\u7684\u5b66\u751f\uff0c\u56e0\u6b64\u770b\u7684\u662f\u5b66\u7c4d\uff0c\u4e0d\u662f\u6237\u7c4d\u3002 \u53e6\uff0c\u822a\u7a7a\u73ed\u4ea6\u62db\u6536\u5916\u5730\u5b66\u751f\u3002 2.\u4e0a\u5317\u6821\u5927\u6982\u8981\u591a\u5c11\u5206\uff1f \u8bf7\u770b\u5e02\u5185\u56db\u533a\u6392\u540d\uff0c\u81f3\u5c11\u56db\u533a\u524d2000\u540d\u3002 3.\u5317\u6821\u62dbXXX\u7279\u957f\u751f\u5417\uff1f \u4e0d\u8981\u4ee5\u5f80\u5e74\u60c5\u51b5\u4e3a\u51c6\uff0c\u8bf7\u4ee5\u5f53\u5e74\u5ea6\u5e02\u6559\u80b2\u5c40\u6838\u51c6\u7684\u62db\u751f\u8ba1\u5212\u4e3a\u51c6\u3002\u7ecf\u9a8c\u4e3b\u4e49\u8981\u4e0d\u5f97\uff0c\u6bd4\u5982\u4e4b\u524d\u5df2\u7ecf\u5f88\u591a\u5e74\u4e0d\u62db\u97f3\u4e50\u7279\u957f\u4e86\uff0c\u7ed3\u679c\u53bb\u5e74\u8ba1\u5212\u91cc\u5c31\u6279\u97f3\u4e50\u7684\u540d\u989d\u4e86\u3002 4.\u5317\u6821\u73ed\u578b\uff1f \u73b0\u6709\u822a\u7a7a\u73ed\uff0c\u666e\u901a\u73ed\uff0c\u91cd\u70b9\u73ed\uff0c\u6cb3\u5317\u7701\u7406\u79d1\u5b9e\u9a8c\u73ed\uff08\u5206\u9ad8\u8003\u73ed\u548c\u7ade\u8d5b\u73ed\uff09\u3002 5.\u5317\u6821\u80fd\u4f4f\u5bbf\u5417\uff1f \u80fd\uff0c\u65b0\u5bbf\u820d\u72ec\u7acb\u536b\u6d74\uff0c\u6c34\u6696\u9f50\u5168\uff0c\u6709\u7a7a\u8c03\uff0c6\u4eba\u95f4\u3002\u5bbf\u820d\u697c\u5927\u6982\u80fd\u4f4f\u4e00\u5343\u4eba\u5de6\u53f3\uff0c\u4f4f\u5bbf\u9700\u7533\u8bf7\u3002","title":"\u62a5\u8003\u6307\u5357"},{"location":"\u62db\u751f\u4fe1\u606f/2south/","text":"\u5357\u6821\u533a \u7248\u6743 \u672c\u9875\u9762\u5185\u5bb9\u6765\u81ea\u767e\u5ea6\u8d34\u5427@OttoHans \u62a5\u8003\u6307\u5357 1.\u5357\u6821\u533a\u7684\u540d\u79f0\uff1f \u73b0\u4e3a\uff1a\u77f3\u5bb6\u5e84\u4e8c\u4e2d\u5b9e\u9a8c\u5b66\u6821 2.\u5357\u6821\u533a\u8d39\u7528\uff1f \u6bcf\u5e74\u6691\u671f\u7269\u4ef7\u5c40\u6838\u51c6\u4ef7\u683c\uff0c\u5982\u679c\u4e0d\u53d8\uff0c\u90a3\u73b0\u9636\u6bb5\u7ee7\u7eed\u6267\u884c\u9876\u683c42000\u5143\u4e09\u5e74\uff08\u542b\u4f4f\u5bbf\u8d39\uff09\u3002 3.\u600e\u4e48\u62a5\u8003\u5357\u6821\u533a\uff1f \u77f3\u5bb6\u5e84\u5730\u533a\u4e2d\u8003\u540e\u7edf\u4e00\u586b\u62a5\u5fd7\u613f\uff0c\u6309\u5206\u6570\u5f55\u53d6\u3002 \u5916\u5730\u53ef\u5728\u6bcf\u5e7411\u6708\u5de6\u53f3\u5f00\u59cb\u8054\u7cfb\u5b66\u6821\u81ea\u8350\uff0c\u4e00\u822c\u6709\u201c\u9884\u5f55\u201d\uff0c\u4f46\u662f\u6700\u540e\u4f9d\u65e7\u8981\u770b\u4e2d\u8003\u6210\u7ee9\u3002 4.\u5357\u6821\u533a\u73ed\u578b\u6709\u4ec0\u4e48\uff0c\u600e\u4e48\u5206\u73ed\uff1f \u73ed\u578b\u540c\u5317\u6821\u533a\u3002\u5206\u73ed\u4e3a\u5165\u5b66\u65f6\u7684\u5206\u73ed\u8003\u8bd5\u3002 \u5bf9\u4e8e\u77f3\u5bb6\u5e84\u5e02\u533a\u751f\u6e90\u53ef\u6309\u4e2d\u8003\u6210\u7ee9\u5212\u5b9a\u73ed\u7ea7\uff0c\u4f46\u4ecd\u9700\u53c2\u52a0\u5206\u73ed\u8003\u8bd5\u3002 \u5916\u5730\u751f\u6e90\u90e8\u5206\u53ef\u80fd\u4f1a\u5728\u201c\u9884\u5f55\u201d\u65f6\u88ab\u4fdd\u8bc1\u73ed\u578b\uff0c\u4f46\u4f9d\u65e7\u8981\u53c2\u52a0\u5206\u73ed\u8003\u8bd5\u3002 \u4ee5\u4e0a\u4e24\u79cd\u60c5\u51b5\u4e2d\uff0c\u5206\u73ed\u8003\u8bd5\u524d\u7684\u73ed\u578b\u4e3a\u4fdd\u5e95\u73ed\u578b\uff0c\u5982\u679c\u5206\u73ed\u6210\u7ee9\u597d\uff0c\u53ef\u63d0\u5347\u73ed\u578b\u3002 5.\u600e\u4e48\u8054\u7cfb\u5357\u6821\u62db\u751f\u8001\u5e08\uff1f \u5916\u5730\u6253\u7535\u8bdd\u8054\u7cfb\u62db\u751f\u7ec4\uff0c\u7535\u8bdd\u89c1\u6821\u7f51\u548c\u5b66\u6821\u516c\u53f7\u3002 6.\u4ec0\u4e48\u6210\u7ee9\u53ef\u4ee5\u4e0a\u5357\u6821\u533a\uff1f \u77f3\u5bb6\u5e84\u672c\u5e02\uff0c\u56db\u533a\u524d3000\u540d\u3002 \u5916\u5730\u7531\u4e8e\u5404\u5730\u62db\u751f\u6570\u91cf\u4e0d\u5b9a\uff0c\u65e0\u6cd5\u4e00\u6982\u800c\u8bba\uff0c\u4f46\u53ef\u5927\u81f4\u8ba4\u4e3a\u5728\u62db\u751f\u8f83\u591a\u533a\u57df\u4f18\u52bf\u521d\u4e2d\u7684\u5e74\u7ea7\u524d10\u95ee\u9898\u4e0d\u5927\uff0c\u5177\u4f53\u60c5\u51b5\u8bf7\u8054\u7cfb\u62db\u751f\u7ec4 7.\u5357\u6821\u6709\u62db\u751f\u8003\u8bd5\u5417\uff1f \u539f\u5219\u4e0a\u4e0d\u5141\u8bb8\uff0c\u5b9e\u9645\u4e0a\u6709\u65f6\u5019\u6709\uff0c\u4f46\u4e0d\u4e00\u5b9a\u6709\u3002 8.\u5916\u7701\u80fd\u4e0d\u80fd\u4e0a\u5357\u6821\u533a\uff1f \u4e00\u822c\u81f3\u5c11\u6237\u7c4d\u6216\u8005\u5b66\u7c4d\u5728\u6cb3\u5317\u7701\u624d\u884c\u3002 9.\u5357\u6821\u7279\u957f\u751f\uff1f \u4e0d\u8981\u4ee5\u5f80\u5e74\u60c5\u51b5\u4e3a\u51c6\uff0c\u8bf7\u4ee5\u5f53\u5e74\u5ea6\u5e02\u6559\u80b2\u5c40\u6838\u51c6\u7684\u62db\u751f\u8ba1\u5212\u4e3a\u51c6\u3002\u5357\u6821\u827a\u672f\u751f\u6709\u7684\u5e74\u5ea6\u6709\u6821\u8003\u3002","title":"\u5357\u6821\u533a"},{"location":"\u62db\u751f\u4fe1\u606f/2south/#_1","text":"","title":"\u5357\u6821\u533a"},{"location":"\u62db\u751f\u4fe1\u606f/2south/#_2","text":"\u672c\u9875\u9762\u5185\u5bb9\u6765\u81ea\u767e\u5ea6\u8d34\u5427@OttoHans","title":"\u7248\u6743"},{"location":"\u62db\u751f\u4fe1\u606f/2south/#_3","text":"1.\u5357\u6821\u533a\u7684\u540d\u79f0\uff1f \u73b0\u4e3a\uff1a\u77f3\u5bb6\u5e84\u4e8c\u4e2d\u5b9e\u9a8c\u5b66\u6821 2.\u5357\u6821\u533a\u8d39\u7528\uff1f \u6bcf\u5e74\u6691\u671f\u7269\u4ef7\u5c40\u6838\u51c6\u4ef7\u683c\uff0c\u5982\u679c\u4e0d\u53d8\uff0c\u90a3\u73b0\u9636\u6bb5\u7ee7\u7eed\u6267\u884c\u9876\u683c42000\u5143\u4e09\u5e74\uff08\u542b\u4f4f\u5bbf\u8d39\uff09\u3002 3.\u600e\u4e48\u62a5\u8003\u5357\u6821\u533a\uff1f \u77f3\u5bb6\u5e84\u5730\u533a\u4e2d\u8003\u540e\u7edf\u4e00\u586b\u62a5\u5fd7\u613f\uff0c\u6309\u5206\u6570\u5f55\u53d6\u3002 \u5916\u5730\u53ef\u5728\u6bcf\u5e7411\u6708\u5de6\u53f3\u5f00\u59cb\u8054\u7cfb\u5b66\u6821\u81ea\u8350\uff0c\u4e00\u822c\u6709\u201c\u9884\u5f55\u201d\uff0c\u4f46\u662f\u6700\u540e\u4f9d\u65e7\u8981\u770b\u4e2d\u8003\u6210\u7ee9\u3002 4.\u5357\u6821\u533a\u73ed\u578b\u6709\u4ec0\u4e48\uff0c\u600e\u4e48\u5206\u73ed\uff1f \u73ed\u578b\u540c\u5317\u6821\u533a\u3002\u5206\u73ed\u4e3a\u5165\u5b66\u65f6\u7684\u5206\u73ed\u8003\u8bd5\u3002 \u5bf9\u4e8e\u77f3\u5bb6\u5e84\u5e02\u533a\u751f\u6e90\u53ef\u6309\u4e2d\u8003\u6210\u7ee9\u5212\u5b9a\u73ed\u7ea7\uff0c\u4f46\u4ecd\u9700\u53c2\u52a0\u5206\u73ed\u8003\u8bd5\u3002 \u5916\u5730\u751f\u6e90\u90e8\u5206\u53ef\u80fd\u4f1a\u5728\u201c\u9884\u5f55\u201d\u65f6\u88ab\u4fdd\u8bc1\u73ed\u578b\uff0c\u4f46\u4f9d\u65e7\u8981\u53c2\u52a0\u5206\u73ed\u8003\u8bd5\u3002 \u4ee5\u4e0a\u4e24\u79cd\u60c5\u51b5\u4e2d\uff0c\u5206\u73ed\u8003\u8bd5\u524d\u7684\u73ed\u578b\u4e3a\u4fdd\u5e95\u73ed\u578b\uff0c\u5982\u679c\u5206\u73ed\u6210\u7ee9\u597d\uff0c\u53ef\u63d0\u5347\u73ed\u578b\u3002 5.\u600e\u4e48\u8054\u7cfb\u5357\u6821\u62db\u751f\u8001\u5e08\uff1f \u5916\u5730\u6253\u7535\u8bdd\u8054\u7cfb\u62db\u751f\u7ec4\uff0c\u7535\u8bdd\u89c1\u6821\u7f51\u548c\u5b66\u6821\u516c\u53f7\u3002 6.\u4ec0\u4e48\u6210\u7ee9\u53ef\u4ee5\u4e0a\u5357\u6821\u533a\uff1f \u77f3\u5bb6\u5e84\u672c\u5e02\uff0c\u56db\u533a\u524d3000\u540d\u3002 \u5916\u5730\u7531\u4e8e\u5404\u5730\u62db\u751f\u6570\u91cf\u4e0d\u5b9a\uff0c\u65e0\u6cd5\u4e00\u6982\u800c\u8bba\uff0c\u4f46\u53ef\u5927\u81f4\u8ba4\u4e3a\u5728\u62db\u751f\u8f83\u591a\u533a\u57df\u4f18\u52bf\u521d\u4e2d\u7684\u5e74\u7ea7\u524d10\u95ee\u9898\u4e0d\u5927\uff0c\u5177\u4f53\u60c5\u51b5\u8bf7\u8054\u7cfb\u62db\u751f\u7ec4 7.\u5357\u6821\u6709\u62db\u751f\u8003\u8bd5\u5417\uff1f \u539f\u5219\u4e0a\u4e0d\u5141\u8bb8\uff0c\u5b9e\u9645\u4e0a\u6709\u65f6\u5019\u6709\uff0c\u4f46\u4e0d\u4e00\u5b9a\u6709\u3002 8.\u5916\u7701\u80fd\u4e0d\u80fd\u4e0a\u5357\u6821\u533a\uff1f \u4e00\u822c\u81f3\u5c11\u6237\u7c4d\u6216\u8005\u5b66\u7c4d\u5728\u6cb3\u5317\u7701\u624d\u884c\u3002 9.\u5357\u6821\u7279\u957f\u751f\uff1f \u4e0d\u8981\u4ee5\u5f80\u5e74\u60c5\u51b5\u4e3a\u51c6\uff0c\u8bf7\u4ee5\u5f53\u5e74\u5ea6\u5e02\u6559\u80b2\u5c40\u6838\u51c6\u7684\u62db\u751f\u8ba1\u5212\u4e3a\u51c6\u3002\u5357\u6821\u827a\u672f\u751f\u6709\u7684\u5e74\u5ea6\u6709\u6821\u8003\u3002","title":"\u62a5\u8003\u6307\u5357"},{"location":"\u62db\u751f\u4fe1\u606f/3runde/","text":"\u6da6\u5fb7\u6821\u533a \u7248\u6743 \u672c\u9875\u9762\u5185\u5bb9\u6765\u81ea\u767e\u5ea6\u8d34\u5427@OttoHans \u62a5\u8003\u6307\u5357 1.\u6da6\u5fb7\u5b66\u6821\u600e\u4e48\u6837\uff1f \u201c\u8fd9\u9152\u600e\u4e48\u6837\u554a\uff1f\u201d 2.\u6da6\u5fb7\u5b66\u6821\u5e08\u8d44\u600e\u4e48\u6837\uff1f \u81ea\u6709\u5e08\u8d44\u548c\u4e8c\u4e2d\u4ee3\u57f9\u5e08\u8d44\u4e3a\u4e3b\uff0c\u6709\u5357\u5317\u6821\u501f\u8c03\u7684\u8001\u5e08\u3002\u7ba1\u7406\u5c42\u90fd\u662f\u5357\u5317\u6821\u8c03\u8fc7\u53bb\u7684\u3002 \u6da6\u5fb7\u201c\u7701\u7406\u201d\u5e08\u8d44\u8fd8\u662f\u8d28\u91cf\u5f88\u9ad8\u7684\u3002 3.\u6da6\u5fb7\u6210\u7ee9\u5982\u4f55\uff1f \u6682\u65f6\u8fd8\u6ca1\u6bd5\u4e1a\u751f\uff0c\u7b492020\u5e74\u9ad8\u8003\u3002 4.\u6da6\u5fb7\u6709\u7ade\u8d5b\u5417\uff1f \u73b0\u5728\u8bf4\u8d77\u6765\u4e5f\u7b97\u6709\uff0c\u4f46\u89c4\u6a21\u5c0f\u6c34\u5e73\u4f4e\uff08\u76f8\u5bf9\uff09\uff0c\u95e8\u7c7b\u4e0d\u5168\u3002 5.\u6da6\u5fb7\u7684\u73ed\u578b\uff1f \u666e\u901a\u73ed\uff0c\u91cd\u70b9\u73ed\uff0c\u521b\u65b0\u5b9e\u9a8c\u73ed\uff0c\u201c\u7701\u7406\u79d1\u5b9e\u9a8c\u73ed\u201d\u3002 6.\u6da6\u5fb7\u7684\u8d39\u7528\uff1f \u7406\u8bba\u4e0a\u7b49\u6691\u671f\u7269\u4ef7\u5c40\u6838\u51c6\uff0c\u5982\u679c\u4e0d\u53d8\u7684\u8bdd\u8fd8\u662f18000\u5143/\u5e74\uff08\u6700\u9ad8\uff09\u3002 7.\u6da6\u5fb7\u600e\u4e48\u62db\u751f\uff0c\u600e\u4e48\u5206\u73ed\uff1f \u6a21\u5f0f\u540c\u5357\u6821\u3002 8.\u591a\u5c11\u5206\u80fd\u53bb\u6da6\u5fb7\uff1f \u5916\u5730\u4e0d\u77e5\uff0c\u672c\u5730\u5c1a\u4e0d\u7a33\u5b9a\uff0c\u53bb\u5e74\u6700\u4f4e561\u5206\uff0c\u56db\u533a4353\u540d\u3002","title":"\u6da6\u5fb7\u6821\u533a"},{"location":"\u62db\u751f\u4fe1\u606f/3runde/#_1","text":"","title":"\u6da6\u5fb7\u6821\u533a"},{"location":"\u62db\u751f\u4fe1\u606f/3runde/#_2","text":"\u672c\u9875\u9762\u5185\u5bb9\u6765\u81ea\u767e\u5ea6\u8d34\u5427@OttoHans","title":"\u7248\u6743"},{"location":"\u62db\u751f\u4fe1\u606f/3runde/#_3","text":"1.\u6da6\u5fb7\u5b66\u6821\u600e\u4e48\u6837\uff1f \u201c\u8fd9\u9152\u600e\u4e48\u6837\u554a\uff1f\u201d 2.\u6da6\u5fb7\u5b66\u6821\u5e08\u8d44\u600e\u4e48\u6837\uff1f \u81ea\u6709\u5e08\u8d44\u548c\u4e8c\u4e2d\u4ee3\u57f9\u5e08\u8d44\u4e3a\u4e3b\uff0c\u6709\u5357\u5317\u6821\u501f\u8c03\u7684\u8001\u5e08\u3002\u7ba1\u7406\u5c42\u90fd\u662f\u5357\u5317\u6821\u8c03\u8fc7\u53bb\u7684\u3002 \u6da6\u5fb7\u201c\u7701\u7406\u201d\u5e08\u8d44\u8fd8\u662f\u8d28\u91cf\u5f88\u9ad8\u7684\u3002 3.\u6da6\u5fb7\u6210\u7ee9\u5982\u4f55\uff1f \u6682\u65f6\u8fd8\u6ca1\u6bd5\u4e1a\u751f\uff0c\u7b492020\u5e74\u9ad8\u8003\u3002 4.\u6da6\u5fb7\u6709\u7ade\u8d5b\u5417\uff1f \u73b0\u5728\u8bf4\u8d77\u6765\u4e5f\u7b97\u6709\uff0c\u4f46\u89c4\u6a21\u5c0f\u6c34\u5e73\u4f4e\uff08\u76f8\u5bf9\uff09\uff0c\u95e8\u7c7b\u4e0d\u5168\u3002 5.\u6da6\u5fb7\u7684\u73ed\u578b\uff1f \u666e\u901a\u73ed\uff0c\u91cd\u70b9\u73ed\uff0c\u521b\u65b0\u5b9e\u9a8c\u73ed\uff0c\u201c\u7701\u7406\u79d1\u5b9e\u9a8c\u73ed\u201d\u3002 6.\u6da6\u5fb7\u7684\u8d39\u7528\uff1f \u7406\u8bba\u4e0a\u7b49\u6691\u671f\u7269\u4ef7\u5c40\u6838\u51c6\uff0c\u5982\u679c\u4e0d\u53d8\u7684\u8bdd\u8fd8\u662f18000\u5143/\u5e74\uff08\u6700\u9ad8\uff09\u3002 7.\u6da6\u5fb7\u600e\u4e48\u62db\u751f\uff0c\u600e\u4e48\u5206\u73ed\uff1f \u6a21\u5f0f\u540c\u5357\u6821\u3002 8.\u591a\u5c11\u5206\u80fd\u53bb\u6da6\u5fb7\uff1f \u5916\u5730\u4e0d\u77e5\uff0c\u672c\u5730\u5c1a\u4e0d\u7a33\u5b9a\uff0c\u53bb\u5e74\u6700\u4f4e561\u5206\uff0c\u56db\u533a4353\u540d\u3002","title":"\u62a5\u8003\u6307\u5357"},{"location":"\u62db\u751f\u4fe1\u606f/4west/","text":"\u897f\u6821\u533a \u7248\u6743 \u672c\u9875\u9762\u5185\u5bb9\u6765\u81ea\u767e\u5ea6\u8d34\u5427@OttoHans \u62a5\u8003\u6307\u5357 1.\u897f\u6821\u533a\u73ed\u578b\uff1f \u5b9e\u9a8c\u73ed\uff0c\u91cd\u70b9\u73ed\uff0c\u666e\u901a\u73ed\u3002 2.\u591a\u5c11\u5206\u80fd\u53bb\u897f\u6821\u533a\uff1f \u5927\u6982\u5e02\u5185\u56db\u533a6\u5343\u540d\uff0c\u4eca\u5e74\u53ef\u80fd\u8fd8\u4f1a\u6da8 3.\u897f\u6821\u533a\u9ad8\u8003\u6210\u7ee9\u5982\u4f55\uff1f \u5b98\u65b9\u6570\u636e\uff1a2018\u5e74\u5171\u56db\u4e2a\u6bd5\u4e1a\u73ed\uff0c\u672c\u79d1\u738799%\uff0c150\u4eba\u672c\u4e00\u4e0a\u7ebf\uff0c23\u4eba600\u5206\u4ee5\u4e0a\u3002\u5b9e\u9a8c\u73ed\u517146\u4eba\u9ad8\u8003\uff0c45\u4eba\u672c\u4e00\u4e0a\u7ebf\u3002 4.\u5728\u897f\u6821\u533a\u6210\u7ee9\u4f18\u79c0\u771f\u7684\u53ef\u4ee5\u8c03\u5230\u5317\u6821\u533a\u5b66\u4e60\u5417\uff1f \u96c6\u56e2\u5185\u90e8\u6709\u8fd9\u4e2a\u653f\u7b56\u3002 5.\u897f\u6821\u533a\u5e08\u8d44\u600e\u4e48\u6837\uff1f \u4ece\u521d\u4e2d\u5230\u9ad8\u4e2d\u90fd\u6709\u539f\u4e8c\u4e2d\u8001\u4e09\u6821\uff08\u5317\u3001\u5357\u3001\u77f3\u95e8\u5b9e\u9a8c\uff09\u501f\u8c03\u8fc7\u53bb\u7684\u8001\u5e08\uff0c\u4f46\u6570\u91cf\u6709\u9650\u3002","title":"\u897f\u6821\u533a"},{"location":"\u62db\u751f\u4fe1\u606f/4west/#_1","text":"","title":"\u897f\u6821\u533a"},{"location":"\u62db\u751f\u4fe1\u606f/4west/#_2","text":"\u672c\u9875\u9762\u5185\u5bb9\u6765\u81ea\u767e\u5ea6\u8d34\u5427@OttoHans","title":"\u7248\u6743"},{"location":"\u62db\u751f\u4fe1\u606f/4west/#_3","text":"1.\u897f\u6821\u533a\u73ed\u578b\uff1f \u5b9e\u9a8c\u73ed\uff0c\u91cd\u70b9\u73ed\uff0c\u666e\u901a\u73ed\u3002 2.\u591a\u5c11\u5206\u80fd\u53bb\u897f\u6821\u533a\uff1f \u5927\u6982\u5e02\u5185\u56db\u533a6\u5343\u540d\uff0c\u4eca\u5e74\u53ef\u80fd\u8fd8\u4f1a\u6da8 3.\u897f\u6821\u533a\u9ad8\u8003\u6210\u7ee9\u5982\u4f55\uff1f \u5b98\u65b9\u6570\u636e\uff1a2018\u5e74\u5171\u56db\u4e2a\u6bd5\u4e1a\u73ed\uff0c\u672c\u79d1\u738799%\uff0c150\u4eba\u672c\u4e00\u4e0a\u7ebf\uff0c23\u4eba600\u5206\u4ee5\u4e0a\u3002\u5b9e\u9a8c\u73ed\u517146\u4eba\u9ad8\u8003\uff0c45\u4eba\u672c\u4e00\u4e0a\u7ebf\u3002 4.\u5728\u897f\u6821\u533a\u6210\u7ee9\u4f18\u79c0\u771f\u7684\u53ef\u4ee5\u8c03\u5230\u5317\u6821\u533a\u5b66\u4e60\u5417\uff1f \u96c6\u56e2\u5185\u90e8\u6709\u8fd9\u4e2a\u653f\u7b56\u3002 5.\u897f\u6821\u533a\u5e08\u8d44\u600e\u4e48\u6837\uff1f \u4ece\u521d\u4e2d\u5230\u9ad8\u4e2d\u90fd\u6709\u539f\u4e8c\u4e2d\u8001\u4e09\u6821\uff08\u5317\u3001\u5357\u3001\u77f3\u95e8\u5b9e\u9a8c\uff09\u501f\u8c03\u8fc7\u53bb\u7684\u8001\u5e08\uff0c\u4f46\u6570\u91cf\u6709\u9650\u3002","title":"\u62a5\u8003\u6307\u5357"},{"location":"\u62db\u751f\u4fe1\u606f/5shimen/","text":"\u77f3\u95e8\u6821\u533a \u7248\u6743 \u672c\u9875\u9762\u5185\u5bb9\u6765\u81ea\u767e\u5ea6\u8d34\u5427@OttoHans \u77f3\u95e8\u5b9e\u9a8c\u9ad8\u4e2d\u7bc7\uff08\u5373\u56fd\u9645\u90e8\uff09 1.\u4ec0\u4e48\u662f\u77f3\u95e8\u5b9e\u9a8c\u5b66\u6821\u7684\u9ad8\u4e2d\u73ed\uff1f \u5373\u77f3\u95e8\u5b9e\u9a8c\u5b66\u6821\u56fd\u9645\u90e8\uff0c\u8be5\u6821\u53e3\u5f84\u4e0a\u8fd9\u662f\u201c\u539f\u4e8c\u4e2d\u56fd\u9645\u90e8\u7684\u5ef6\u7eed\u201d\u3002\u77f3\u95e8\u5b9e\u9a8c\u56fd\u9645\u90e8\u4e3a\u77f3\u95e8\u5b9e\u9a8c\u5b66\u6821\u4e0e\u5317\u4eac\u738b\u5e9c\u5b66\u6821\u5408\u4f5c\u529e\u5b66\u3002 2.\u77f3\u95e8\u5b9e\u9a8c\u56fd\u9645\u90e8\u7684\u73ed\u578b\uff0c\u63d0\u4f9b\u4ec0\u4e48\u8bfe\u7a0b\uff1f \u56fd\u9645\u90e8\u73ed\u578b\u4e3a\u7f8e\u52a0\u56fd\u9645\u73ed\uff0c\u5f00\u8bbe\u8bfe\u7a0b\u5982\u4e0b\uff1a \uff081\uff09\u666e\u901a\u9ad8\u4e2d\u8bfe\u7a0b\u4e2d\u6d89\u53ca\u6cb3\u5317\u7701\u5b66\u4e1a\u6c34\u5e73\u6d4b\u8bd5\u7684\u8bfe\u7a0b\u5185\u5bb9\uff1b \uff082\uff09Pre-AP\u548cAP\u8bfe\u7a0b\uff1b \uff083\uff09\u82f1\u8bed\u8bfe\u7a0b\uff1b \uff084\uff09\u51fa\u56fd\u8003\u8bd5\u57f9\u8bad\uff08\u6258\u798f\u3001STA\u7b49\uff09\uff1b \uff085\uff09\u5347\u5b66\u6307\u5bfc\u3002 3.\u77f3\u95e8\u5b9e\u9a8c\u56fd\u9645\u90e8\u7684\u62db\u751f\u6761\u4ef6\uff1f \u9762\u5411\u5f53\u5e74\u5ea6\u521d\u4e2d\u5e94\u5c4a\u6bd5\u4e1a\u751f\u6216\u9ad8\u4e00\u5728\u8bfb\uff0c\u5177\u6709\u6cb3\u5317\u7701\u6237\u7c4d\uff0c\u6709\u610f\u7559\u5b66\u7f8e\u56fd\u3001\u52a0\u62ff\u5927\u540d\u6821\u8fdb\u884c\u672c\u79d1\u5b66\u4e60\u7684\u5b66\u751f\u3002 4.\u77f3\u95e8\u5b9e\u9a8c\u56fd\u9645\u90e8\u600e\u4e48\u5f55\u53d6\uff1f \u56e0\u4e3a\u6d89\u53ca\u56fd\u5185\u9ad8\u4e2d\u5b66\u7c4d\u548c\u6bd5\u4e1a\u8bc1\uff0c\u867d\u7136\u8981\u5411\u56fd\u9645\u90e8\u62a5\u540d\uff0c\u4f46\u6700\u540e\u8fd8\u662f\u8981\u901a\u8fc7\u4e2d\u8003\u5f55\u53d6\uff0c\u53ea\u662f\u6807\u51c6\u66f4\u7075\u6d3b\u3002","title":"\u77f3\u95e8\u6821\u533a"},{"location":"\u62db\u751f\u4fe1\u606f/5shimen/#_1","text":"","title":"\u77f3\u95e8\u6821\u533a"},{"location":"\u62db\u751f\u4fe1\u606f/5shimen/#_2","text":"\u672c\u9875\u9762\u5185\u5bb9\u6765\u81ea\u767e\u5ea6\u8d34\u5427@OttoHans","title":"\u7248\u6743"},{"location":"\u62db\u751f\u4fe1\u606f/5shimen/#_3","text":"1.\u4ec0\u4e48\u662f\u77f3\u95e8\u5b9e\u9a8c\u5b66\u6821\u7684\u9ad8\u4e2d\u73ed\uff1f \u5373\u77f3\u95e8\u5b9e\u9a8c\u5b66\u6821\u56fd\u9645\u90e8\uff0c\u8be5\u6821\u53e3\u5f84\u4e0a\u8fd9\u662f\u201c\u539f\u4e8c\u4e2d\u56fd\u9645\u90e8\u7684\u5ef6\u7eed\u201d\u3002\u77f3\u95e8\u5b9e\u9a8c\u56fd\u9645\u90e8\u4e3a\u77f3\u95e8\u5b9e\u9a8c\u5b66\u6821\u4e0e\u5317\u4eac\u738b\u5e9c\u5b66\u6821\u5408\u4f5c\u529e\u5b66\u3002 2.\u77f3\u95e8\u5b9e\u9a8c\u56fd\u9645\u90e8\u7684\u73ed\u578b\uff0c\u63d0\u4f9b\u4ec0\u4e48\u8bfe\u7a0b\uff1f \u56fd\u9645\u90e8\u73ed\u578b\u4e3a\u7f8e\u52a0\u56fd\u9645\u73ed\uff0c\u5f00\u8bbe\u8bfe\u7a0b\u5982\u4e0b\uff1a \uff081\uff09\u666e\u901a\u9ad8\u4e2d\u8bfe\u7a0b\u4e2d\u6d89\u53ca\u6cb3\u5317\u7701\u5b66\u4e1a\u6c34\u5e73\u6d4b\u8bd5\u7684\u8bfe\u7a0b\u5185\u5bb9\uff1b \uff082\uff09Pre-AP\u548cAP\u8bfe\u7a0b\uff1b \uff083\uff09\u82f1\u8bed\u8bfe\u7a0b\uff1b \uff084\uff09\u51fa\u56fd\u8003\u8bd5\u57f9\u8bad\uff08\u6258\u798f\u3001STA\u7b49\uff09\uff1b \uff085\uff09\u5347\u5b66\u6307\u5bfc\u3002 3.\u77f3\u95e8\u5b9e\u9a8c\u56fd\u9645\u90e8\u7684\u62db\u751f\u6761\u4ef6\uff1f \u9762\u5411\u5f53\u5e74\u5ea6\u521d\u4e2d\u5e94\u5c4a\u6bd5\u4e1a\u751f\u6216\u9ad8\u4e00\u5728\u8bfb\uff0c\u5177\u6709\u6cb3\u5317\u7701\u6237\u7c4d\uff0c\u6709\u610f\u7559\u5b66\u7f8e\u56fd\u3001\u52a0\u62ff\u5927\u540d\u6821\u8fdb\u884c\u672c\u79d1\u5b66\u4e60\u7684\u5b66\u751f\u3002 4.\u77f3\u95e8\u5b9e\u9a8c\u56fd\u9645\u90e8\u600e\u4e48\u5f55\u53d6\uff1f \u56e0\u4e3a\u6d89\u53ca\u56fd\u5185\u9ad8\u4e2d\u5b66\u7c4d\u548c\u6bd5\u4e1a\u8bc1\uff0c\u867d\u7136\u8981\u5411\u56fd\u9645\u90e8\u62a5\u540d\uff0c\u4f46\u6700\u540e\u8fd8\u662f\u8981\u901a\u8fc7\u4e2d\u8003\u5f55\u53d6\uff0c\u53ea\u662f\u6807\u51c6\u66f4\u7075\u6d3b\u3002","title":"\u77f3\u95e8\u5b9e\u9a8c\u9ad8\u4e2d\u7bc7\uff08\u5373\u56fd\u9645\u90e8\uff09"},{"location":"\u62db\u751f\u4fe1\u606f/6junior/","text":"\u4e8c\u4e2d\u521d\u4e2d \u7248\u6743 \u672c\u9875\u9762\u5185\u5bb9\u6765\u81ea\u767e\u5ea6\u8d34\u5427@OttoHans \u4e8c\u4e2d\u521d\u4e2d\u95ee\u9898 1.\u4e8c\u4e2d\u521d\u4e2d\u5b66\u533a\uff08\u7247\u5185\u8303\u56f4\uff09\uff1f \u9664\u4e86\u897f\u6821\u5916\uff0c\u6da6\u5fb7\u548c\u77f3\u95e8\u4f5c\u4e3a\u6c11\u529e\u5b66\u6821\u662f\u6ca1\u6709\u5206\u5b66\u533a\u7684\u3002 \u897f\u6821\u5b66\u533a\u95ee\u9898\u8bf7\u5173\u6ce8\u5e02\u6559\u80b2\u5c40\u6bcf\u5e74\u66f4\u65b0\u7684\u5b66\u533a\u5730\u56fe\uff0c\u6211\u73b0\u5728\u4e5f\u53ea\u80fd\u8bf42018\u5e74\u7684\u7ed3\u679c\uff0c\u8fd9\u4e2a\u5730\u56fe\u6ca1\u6709\u90fd\u6709\u53ef\u80fd\u53d8\u5316\uff08\u53cd\u6b63\u5212\u7247\u8fd9\u4e8b\uff0c\u5411\u6765\u53d8\u6765\u53d8\u53bb\u7684\uff09 2018\u5e74\u897f\u6821\u5b66\u533a\u8303\u56f4\uff1a\uff081\uff09\u6c34\u6e90\u8857\u4ee5\u4e1c\uff0c\u7ef4\u660e\u5927\u8857\u4ee5\u897f\uff0c\u548c\u5e73\u897f\u8def\u4ee5\u5357\uff0c\u65b0\u534e\u8def\u4ee5\u5317\uff1b\uff082\uff09\u7ea2\u519b\u5927\u8857\u4ee5\u897f\uff0c\u6cf0\u534e\u8857\u4ee5\u4e1c\uff08\u542b\u4e1c\u4fa7\u8857\u9762\uff09\uff0c\u548c\u5e73\u897f\u8def\u4ee5\u5317\uff0c\u8054\u76df\u8def\u4ee5\u5357\uff1b\uff083\uff09\u6c34\u6e90\u8857\u897f\u4fa7\u8857\u9762(\u6c34\u573a\u80e1\u540c-\u65b0\u534e\u8def)\u3002 \u6211\u8bdd\u8bb2\u5b8c\uff0c\u8bf7\u6253\u5f00\u5730\u56fe\u81ea\u5df1\u753b\u5427\u3002 2.\u90a3\u4e48\u600e\u4e48\u62a5\u540d\uff1f \u50cf\u897f\u6821\u8fd9\u79cd\u516c\u529e\u6821\u6211\u89c9\u5f97\u4e0d\u7528\u591a\u8bf4\u4e86\uff0c\u6839\u636e\u6761\u4ef6\uff0c\u7b26\u5408\u7684\u53bb\u628a\u8be5\u4ea4\u7684\u6750\u6599\u4ea4\u4e86\u5c31\u884c\u4e86\u3002 \u81f3\u4e8e\u6da6\u5fb7\u548c\u77f3\u95e8\uff0c\u8bf7\u5173\u6ce8\u4e24\u6821\u7f51\u7ad9\u548c\u516c\u4f17\u53f7\uff0c\u4e00\u822c\u6709\u7f51\u4e0a\u62a5\u540d\u8868\uff0c\u4e5f\u4f1a\u63d0\u4f9b\u62db\u751f\u8054\u7cfb\u65b9\u5f0f\u3002 3.\u5916\u5730\u5b66\u751f\u600e\u4e48\u4e0a\u4e8c\u4e2d\u521d\u4e2d\uff1f \u5982\u679c\u5bb6\u957f\u975e\u5728\u77f3\u5de5\u4f5c\u5c45\u4f4f\u7684\u8bdd\uff0c\u4e0a\u897f\u6821\u6709\u4e00\u5b9a\u96be\u5ea6\uff0c\u4f46\u6da6\u5fb7\u548c\u77f3\u95e8\u6ca1\u4e8b\uff0c\u8be5\u600e\u4e48\u62a5\u540d\u600e\u4e48\u62a5\u540d\u5c31\u884c\u3002 4.\u4e8c\u4e2d\u7684\u521d\u4e2d\u600e\u4e48\u6837\uff1f \u897f\u6821\u548c\u4e94\u4e2d\u65f6\u671f\u6bd4\uff0c\u6ca1\u4ec0\u4e48\u533a\u522b\u3002\u77f3\u95e8\u8d8a\u6765\u8d8a\u597d\u4f46\u662f\u5c16\u5b50\u8fd8\u662f\u8f83\u591a\u7684\u6d41\u5411\u5357\u6821\uff0c\u4e8c\u4e2d\u7279\u8272\u5185\u5377\u5316\u8d8b\u52bf\u5c3d\u663e\u3002 \u6da6\u5fb7\uff0c\u6682\u65e0\u6bd5\u4e1a\u751f\uff0c\u5c1a\u4e0d\u660e\u786e\uff0c\u7b492020\u5e74\u4e2d\u8003\u540e\u518d\u8bf4\u3002 \u6574\u4f53\u4e0a\u4e8c\u4e2d\u521d\u4e2d\u5728\u6211\u5e02\u8fd8\u662f\u7b2c\u4e8c\u68af\u961f\uff08\u5b58\u7591\uff0c\u53ef\u80fd\u8bf4\u9ad8\u4e86\uff09\u3002","title":"\u4e8c\u4e2d\u521d\u4e2d"},{"location":"\u62db\u751f\u4fe1\u606f/6junior/#_1","text":"","title":"\u4e8c\u4e2d\u521d\u4e2d"},{"location":"\u62db\u751f\u4fe1\u606f/6junior/#_2","text":"\u672c\u9875\u9762\u5185\u5bb9\u6765\u81ea\u767e\u5ea6\u8d34\u5427@OttoHans","title":"\u7248\u6743"},{"location":"\u62db\u751f\u4fe1\u606f/6junior/#_3","text":"1.\u4e8c\u4e2d\u521d\u4e2d\u5b66\u533a\uff08\u7247\u5185\u8303\u56f4\uff09\uff1f \u9664\u4e86\u897f\u6821\u5916\uff0c\u6da6\u5fb7\u548c\u77f3\u95e8\u4f5c\u4e3a\u6c11\u529e\u5b66\u6821\u662f\u6ca1\u6709\u5206\u5b66\u533a\u7684\u3002 \u897f\u6821\u5b66\u533a\u95ee\u9898\u8bf7\u5173\u6ce8\u5e02\u6559\u80b2\u5c40\u6bcf\u5e74\u66f4\u65b0\u7684\u5b66\u533a\u5730\u56fe\uff0c\u6211\u73b0\u5728\u4e5f\u53ea\u80fd\u8bf42018\u5e74\u7684\u7ed3\u679c\uff0c\u8fd9\u4e2a\u5730\u56fe\u6ca1\u6709\u90fd\u6709\u53ef\u80fd\u53d8\u5316\uff08\u53cd\u6b63\u5212\u7247\u8fd9\u4e8b\uff0c\u5411\u6765\u53d8\u6765\u53d8\u53bb\u7684\uff09 2018\u5e74\u897f\u6821\u5b66\u533a\u8303\u56f4\uff1a\uff081\uff09\u6c34\u6e90\u8857\u4ee5\u4e1c\uff0c\u7ef4\u660e\u5927\u8857\u4ee5\u897f\uff0c\u548c\u5e73\u897f\u8def\u4ee5\u5357\uff0c\u65b0\u534e\u8def\u4ee5\u5317\uff1b\uff082\uff09\u7ea2\u519b\u5927\u8857\u4ee5\u897f\uff0c\u6cf0\u534e\u8857\u4ee5\u4e1c\uff08\u542b\u4e1c\u4fa7\u8857\u9762\uff09\uff0c\u548c\u5e73\u897f\u8def\u4ee5\u5317\uff0c\u8054\u76df\u8def\u4ee5\u5357\uff1b\uff083\uff09\u6c34\u6e90\u8857\u897f\u4fa7\u8857\u9762(\u6c34\u573a\u80e1\u540c-\u65b0\u534e\u8def)\u3002 \u6211\u8bdd\u8bb2\u5b8c\uff0c\u8bf7\u6253\u5f00\u5730\u56fe\u81ea\u5df1\u753b\u5427\u3002 2.\u90a3\u4e48\u600e\u4e48\u62a5\u540d\uff1f \u50cf\u897f\u6821\u8fd9\u79cd\u516c\u529e\u6821\u6211\u89c9\u5f97\u4e0d\u7528\u591a\u8bf4\u4e86\uff0c\u6839\u636e\u6761\u4ef6\uff0c\u7b26\u5408\u7684\u53bb\u628a\u8be5\u4ea4\u7684\u6750\u6599\u4ea4\u4e86\u5c31\u884c\u4e86\u3002 \u81f3\u4e8e\u6da6\u5fb7\u548c\u77f3\u95e8\uff0c\u8bf7\u5173\u6ce8\u4e24\u6821\u7f51\u7ad9\u548c\u516c\u4f17\u53f7\uff0c\u4e00\u822c\u6709\u7f51\u4e0a\u62a5\u540d\u8868\uff0c\u4e5f\u4f1a\u63d0\u4f9b\u62db\u751f\u8054\u7cfb\u65b9\u5f0f\u3002 3.\u5916\u5730\u5b66\u751f\u600e\u4e48\u4e0a\u4e8c\u4e2d\u521d\u4e2d\uff1f \u5982\u679c\u5bb6\u957f\u975e\u5728\u77f3\u5de5\u4f5c\u5c45\u4f4f\u7684\u8bdd\uff0c\u4e0a\u897f\u6821\u6709\u4e00\u5b9a\u96be\u5ea6\uff0c\u4f46\u6da6\u5fb7\u548c\u77f3\u95e8\u6ca1\u4e8b\uff0c\u8be5\u600e\u4e48\u62a5\u540d\u600e\u4e48\u62a5\u540d\u5c31\u884c\u3002 4.\u4e8c\u4e2d\u7684\u521d\u4e2d\u600e\u4e48\u6837\uff1f \u897f\u6821\u548c\u4e94\u4e2d\u65f6\u671f\u6bd4\uff0c\u6ca1\u4ec0\u4e48\u533a\u522b\u3002\u77f3\u95e8\u8d8a\u6765\u8d8a\u597d\u4f46\u662f\u5c16\u5b50\u8fd8\u662f\u8f83\u591a\u7684\u6d41\u5411\u5357\u6821\uff0c\u4e8c\u4e2d\u7279\u8272\u5185\u5377\u5316\u8d8b\u52bf\u5c3d\u663e\u3002 \u6da6\u5fb7\uff0c\u6682\u65e0\u6bd5\u4e1a\u751f\uff0c\u5c1a\u4e0d\u660e\u786e\uff0c\u7b492020\u5e74\u4e2d\u8003\u540e\u518d\u8bf4\u3002 \u6574\u4f53\u4e0a\u4e8c\u4e2d\u521d\u4e2d\u5728\u6211\u5e02\u8fd8\u662f\u7b2c\u4e8c\u68af\u961f\uff08\u5b58\u7591\uff0c\u53ef\u80fd\u8bf4\u9ad8\u4e86\uff09\u3002","title":"\u4e8c\u4e2d\u521d\u4e2d\u95ee\u9898"}]}